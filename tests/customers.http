### 


### 👥 CUSTOMERS API TESTS


### Base endpoint: /api/customers


### 


### This file contains tests for customer management endpoints.


### Update the variables below and run requests with :Rest run


### 


### Authentication required:


### - x-api-key: Global API key


### 


### Note: This endpoint handles both single customer and bulk customer subscriptions.


### The handler creates ShopSubscription entries linking customers to shops.


### 


### ============================================


### VARIABLES - UPDATE THESE FOR YOUR ENVIRONMENT


### ============================================

@apiKey = your-api-key-here
@baseUrl = http://localhost:3000
@customer2Birthday = 1985-05-20
@customer2Name = Jane Smith
@customer2Phone = +19876543210
@customer3Name = Bob Johnson
@customer3Phone = +15555555555
@customerBirthday = 1990-01-15
@customerName = John Doe
@customerPhone = +1234567890
@invalidPhone = 1234567890
@invalidShopCode = INVALID_999
@shopCode = TESTSHOP123


### ============================================


### POST - Subscribe Customer(s) to Shop


### ============================================


### add-single-customer-with-birthday

# Expected: 200 OK
# Creates/links customer to shop with birthday
# Handler: backend/app/api/customers/handler/post.ts:6

POST {{baseUrl}}/api/customers HTTP/1.1
X-Api-Key: {{apiKey}}
Content-Type: application/json

{
  "name": "{{customerName}}",
  "phone": "{{customerPhone}}",
  "shopCode": "{{shopCode}}",
  "birthday": "{{customerBirthday}}"
r


### add-single-customer-without-birthday

# Expected: 200 OK
# Creates/links customer to shop without birthday (optional field)

POST {{baseUrl}}/api/customers HTTP/1.1
X-Api-Key: {{apiKey}}
Content-Type: application/json

{
  "name": "{{customerName}}",
  "phone": "{{customerPhone}}",
  "shopCode": "{{shopCode}}"
}


### add-bulk-customers

# Expected: 200 OK
# Creates/links multiple customers to shop
# Array format for bulk operations

POST {{baseUrl}}/api/customers HTTP/1.1
X-Api-Key: {{apiKey}}
Content-Type: application/json

[
  {
    "birthday": "{{customerBirthday}}",
    "name": "{{customerName}}",
    "phone": "{{customerPhone}}",
    "shopCode": "{{shopCode}}"
  },
  {
    "birthday": "{{customer2Birthday}}",
    "name": "{{customer2Name}}",
    "phone": "{{customer2Phone}}",
    "shopCode": "{{shopCode}}"
  },
  {
    "name": "{{customer3Name}}",
    "phone": "{{customer3Phone}}",
    "shopCode": "{{shopCode}}"
  }
]


### add-bulk-customers-mixed-data

# Expected: 200 OK
# Tests: Some customers with birthday, some without

POST {{baseUrl}}/api/customers HTTP/1.1
X-Api-Key: {{apiKey}}
Content-Type: application/json

[
  {
    "birthday": "{{customerBirthday}}",
    "name": "{{customerName}}",
    "phone": "{{customerPhone}}",
    "shopCode": "{{shopCode}}"
  },
  {
    "name": "{{customer2Name}}",
    "phone": "{{customer2Phone}}",
    "shopCode": "{{shopCode}}"
  }
]


### add-customer-existing-phone

# Expected: 200 OK (Links existing customer to shop)
# Tests: Adding customer with existing phone number (unique identifier)
# Should link existing customer to the shop if not already linked

POST {{baseUrl}}/api/customers HTTP/1.1
X-Api-Key: {{apiKey}}
Content-Type: application/json

{
  "name": "{{customerName}}",
  "phone": "{{customerPhone}}",
  "shopCode": "{{shopCode}}"
}


### add-customer-invalid-phone

# Expected: 400 Bad Request
# Tests: Invalid phone format (must be E.164 format)

POST {{baseUrl}}/api/customers HTTP/1.1
X-Api-Key: {{apiKey}}
Content-Type: application/json

{
  "name": "{{customerName}}",
  "phone": "{{invalidPhone}}",
  "shopCode": "{{shopCode}}"
}


