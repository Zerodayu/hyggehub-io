# HyggeHub API Testing Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file - it contains sensitive keys!

# Base Configuration
BASE_URL=http://localhost:3000
API_KEY=your-api-key-here

# User & Organization IDs (from Clerk)
USER_ID=user_xxxxxxxxxxxxx
ORG_ID=org_xxxxxxxxxxxxx

# Shop Configuration
SHOP_CODE=TESTSHOP123
PHONE_NUMBER=+1234567890

# Test Data
BIRTHDAY=1990-01-15
MESSAGE_TITLE=Spring Sale
MESSAGE_BODY=Get 20% off this weekend!
MESSAGE_EXPIRES=2026-12-31T23:59:59Z

# SMS Testing
SMS_BODY=Hello from HyggeHub! Thank you for subscribing to our updates.
SMS_SENDER=HyggeHub
TEST_PHONE_NUMBER=+4542349115
TEST_PHONE_2=+19876543210
TEST_PHONE_3=+15555555555

# Test IDs (fill these after creating test data)
MESSAGE_ID=msg_xxxxxxxxxxxxx
CUSTOMER_ID=cust_xxxxxxxxxxxxx

# Invalid Test Values (for error testing)
INVALID_SHOP_CODE=INVALID_999
INVALID_USER_ID=user_invalid
INVALID_ORG_ID=org_invalid
INVALID_MESSAGE_ID=msg_invalid
INVALID_CUSTOMER_ID=cust_invalid
INVALID_DATE=not-a-date
INVALID_PHONE=1234567890
